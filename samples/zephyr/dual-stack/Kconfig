menu "Hubble Network Sat-BLE Alternate Sample options"

config HUBBLE_SAT_SAMPLE_NETWORK_ID
    int "Network ID to be used for satellite"
    default 1337
    depends on HUBBLE_SAT_NETWORK_PROTOCOL_DEPRECATED
    help
	Set device's network id for satellite communication.

config SAMPLE_PROVIDE_SAT_BOARD_SUPPORT
    bool "Provide satellite board suport for test purpose"
    default y
    help
	Targets that support satellite must select it, otherwise
	board APIs will be mocked in the sample.

endmenu

source "Kconfig.zephyr"

module = APP
module-str = APP
source "subsys/logging/Kconfig.template.log_config"
